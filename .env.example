# AI Provider Configuration for Translation
# Copy this file to .env and add your API keys for your chosen provider(s).
# Only API keys are stored here — model selection is done via --model flag,
# TUI wizard, or movamc.toml config.
#
# Supported providers:
#   google           → no API key required (free, rate-limited)
#   openai           → uses OPENAI_API_KEY
#   anthropic        → uses ANTHROPIC_API_KEY
#   gemini           → uses GEMINI_API_KEY
#   ollama           → uses OLLAMA_API_BASE (local)
#   litellm          → generic — uses any litellm-compatible key
#   openaicompatible → uses OPENAICOMPATIBLE_API_KEY + OPENAICOMPATIBLE_BASE_URL
#   opencode         → uses OPENCODE_GO_API_KEY (subscribe at opencode.ai/go)

# Provider API keys (only set the ones you intend to use)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_API_BASE=http://localhost:11434

# OpenAI-Compatible provider (any OpenAI-compatible API: vLLM, LM Studio, OpenRouter, etc.)
OPENAICOMPATIBLE_API_KEY=your_api_key_here
OPENAICOMPATIBLE_BASE_URL=http://localhost:8080/v1

# OpenCode Go (https://opencode.ai/go — $5 first month, then $10/month)
OPENCODE_GO_API_KEY=your_opencode_go_api_key_here
# OPENCODE_GO_MODEL=deepseek-v4-flash
# OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1

# ── Web UI server ──────────────────────────────────────
# MOVAMC_HOST=127.0.0.1
# MOVAMC_PORT=8000
# MOVAMC_DEV=0              # set to 1 to enable CORS + Vite HMR
# MOVAMC_DEBUG=0            # set to 1 for debug logging
# MOVAMC_NO_BROWSER=0       # set to 1 to skip opening browser

# ── Optional extras ────────────────────────────────────
# TRANSLATION_MODEL=gpt-4o-mini     # fallback model for all AI providers
# UNRAR_TOOL=C:\Program Files\WinRAR\UnRAR.exe
